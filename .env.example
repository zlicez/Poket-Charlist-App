# Pocket Charlist — environment variables
# Copy this file to .env and fill in the values before running the app.

# PostgreSQL connection string (e.g. Neon, Supabase, local)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Random secret for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-secure-random-string

# Google OAuth 2.0 credentials (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Set to "true" in production when served over HTTPS so cookies get the Secure flag
COOKIE_SECURE=

# Restrict CORS to this origin in production (e.g. https://app.yourdomain.com)
# Leave empty to allow same-origin only (default for single-server deployments)
ALLOWED_ORIGIN=

# Set to "true" to bypass Google OAuth and use a local dev user (never use in production)
LOCAL_DEV=

# HTTP port (default: 5000)
PORT=5000
